# 1. Builder
FROM node:24.12.0-alpine AS builder
WORKDIR /app

# Use upstream UI source (checked out at upstream-ui/ in CI)
COPY upstream-ui/ .

# Remove upstream's config + standaloneSignIn so we don't have two 
RUN rm -f next.config.ts
RUN rm -f src/actions/standalone/standaloneSignIn.tsx

# Override with our Next.js config (replaces upstream's) + standaloneSignIn
COPY next.config.ts ./next.config.ts
COPY standaloneSignIn.tsx ./src/actions/standalone/standaloneSignIn.tsx

# Install deps & build
RUN npm ci
ENV NODE_ENV=production
RUN npm run build

# 2. Runner (multi-arch)
FROM node:24.12.0-alpine AS runner
WORKDIR /app

# Create non-root user
RUN addgroup --system --gid 1001 nodejs \
 && adduser --system --uid 1001 nextjs

# Copy standalone output and required static assets
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

USER nextjs

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
ENV NODE_ENV=production
EXPOSE 3000

CMD ["node", "server.js"]
